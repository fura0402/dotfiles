#!/bin/bash
# Functions of .bashrc
function psdef(){
    if [ -f /usr/local/etc/bash_completion.d/git-prompt.sh ]; then
        source /usr/local/etc/bash_completion.d/git-prompt.sh
        export PS1='\e[01;37m\]╭─\[\e[01;32m\]\u@\h\[\e[01;33m\] \w$(__git_ps1) \n\[\e[01;37m\]╰─|ω･)ﾁﾗ ≺\[\e[0m\] '
        export PS2="         \[\e[01;37m\]≺ \[\e[0m\]"
    else
        export PS1='\e[01;37m\]╭─\[\e[01;32m\]\u@\h\[\e[01;33m\] \w \n\[\e[01;37m\]╰─|ω･)ﾁﾗ ≺\[\e[0m\] '
        export PS2="         \[\e[01;37m\]≺ \[\e[0m\]"
    fi
}
function psdol(){
    export PS1="\[\e[01;36m\]\$ \[\e[0m\]"
}
function prompt_check() {
    prompt_count=$(
        expr 4 \
        + `expr "$(whoami)" : '.*'` \
        + `expr "$(hostname -s)" : '.*'` \
        + `expr "$(pwd | sed -e "s|$HOME\(.*\)|~\1|")" : '.*'` \
        + `expr "$(type __git_ps1 &> /dev/null && __git_ps1)" : '.*'` \
    )
    cols=$(tput cols)
    if [ $cols -le $prompt_count ]; then
        psdol
    else
        psdef
    fi
}

function ls_notice(){
    if [ $# -gt 0 ]; then
        ret=()
        args=("$@")
        for i in $(seq 0 $(expr $# - 1)); do
            if [[ "${args[$i]}" =~ ^- ]]; then
                ret+=("${args[$i]}")
            else
                ret+=("${args[$i]// /\\ }")
            fi
        done
    fi

    if [ -z "$(\ls -A "${PWD}")" ]; then
            echo "The directory is empty."
    else
        if type -a \exa &>/dev/null; then
            eval "exa --icons --color=always ${ret[*]}"
        else
            eval "ls -FG ${ret[*]}"
        fi
    fi
}
function cdls(){
    if [[ $1 =~ \.\..* ]];then
        local dot="$(echo $1 | sed 's|\.||')"
        for i in $(seq 1 ${#dot}); do
            \cd ../
        done
    elif [[ "$*" =~ " " ]]; then
        \cd "${*}" || return 1
    else
        \cd $* || return 1
    fi
    clear -x; printf '\n\e[1;33m%s\e[m\n' "$(pwd)"; printf '\n\e[1;37m%s\e[m\n' ' ls'; ls_notice
}

zls(){
    _z $* 2>&1 #&& printf '\n\e[1;37m%s\e[0m\n' ' ls'; ls_notice
}

function all_unalias(){
    unalias -a
    alias brew='PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin brew'
}

function llvm(){
    export PATH="/usr/local/opt/llvm/bin:$PATH"
    export LDFLAGS="-L/usr/local/opt/llvm/lib"
    export CPPFLAGS="-I/usr/local/opt/llvm/include"
    unset -f llvm
}

function bash_color(){
    for fore in `seq 30 37`; do
        printf "\e[${fore}m \\\e[${fore}m \e[m\n"
        for mode in 1 4 5; do
            printf "\e[${fore};${mode}m \\\e[${fore};${mode}m \e[m"
            for back in `seq 40 47`; do
                printf "\e[${fore};${back};${mode}m \\\e[${fore};${back};${mode}m \e[m"
            done
            echo
        done
        echo
    done
    printf " \\\e[m\n"
}

function tsrun(){
    tsc $1 || return 0
    fileName=$(echo $1 | sed -e "s|\.ts|.js|")
    node $fileName
}
